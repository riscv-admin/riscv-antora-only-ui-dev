{{#if page.attributes.more_details_url}}
<script>
  document.querySelectorAll('.card-more-link:not(:has(a))').forEach(function (el) {
    var a = document.createElement('a')
    a.href = '{{page.attributes.more_details_url}}'
    a.target = '_blank'
    a.rel = 'noopener noreferrer'
    a.textContent = el.textContent.trim() || 'More Details'
    el.textContent = ''
    el.appendChild(a)
  })
</script>
{{else if page.componentVersion.asciidoc.attributes.more_details_url}}
<script>
  document.querySelectorAll('.card-more-link:not(:has(a))').forEach(function (el) {
    var a = document.createElement('a')
    a.href = '{{page.componentVersion.asciidoc.attributes.more_details_url}}'
    a.target = '_blank'
    a.rel = 'noopener noreferrer'
    a.textContent = el.textContent.trim() || 'More Details'
    el.textContent = ''
    el.appendChild(a)
  })
</script>
{{/if}}
<script src="{{{uiRootPath}}}/js/vendor/import.js"></script>
<script src="{{{uiRootPath}}}/js/site.js"></script>
<script async src="{{{uiRootPath}}}/js/vendor/highlight.js"></script>
<script async
    src="{{{uiRootPath}}}/js/vendor/{{#if (asciidocExtensionRegistered '@asciidoctor/tabs')}}asciidoctor{{else}}spring{{/if}}-tabs.js"
    data-sync-storage-key="docs:preferred-tab"></script>
{{#if env.SITE_SEARCH_PROVIDER}}
{{> search-scripts}}
{{/if}}