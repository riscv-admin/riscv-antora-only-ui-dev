{{#unless (and (eq page.component.name "home") (eq page.url "/home/index.html"))}}
<div class="breadcrumbs-container">
  <nav class="breadcrumbs" aria-label="breadcrumbs">
    {{#if page.breadcrumbs}}
    <ul>

      <li><a href="{{siteRootPath}}/home/index.html">RISC-V Specifications</a></li>

      {{!-- Insert overview page breadcrumb for grouped components --}}
      {{#if (or (eq page.component.name "profiles-overview") (isInGroup page.component "profile") (eq page.component.name "profiles"))}}
        <li><a href="{{siteRootPath}}/profiles-overview/index.html">Profiles Overview</a></li>
      {{else if (or (eq page.component.name "hardware-overview") (isInGroup page.component "hardware") (eq page.component.name "hardware"))}}
        <li><a href="{{siteRootPath}}/hardware-overview/index.html">Hardware Overview</a></li>
      {{else if (or (eq page.component.name "trace-debug-ras-overview") (isInGroup page.component "debug-trace-ras"))}}
        <li><a href="{{siteRootPath}}/trace-debug-ras-overview/index.html">Debug, Trace, RAS Overview</a></li>
      {{else if (or (eq page.component.name "platform-software-overview") (isInGroup page.component "platform-software") (eq page.component.name "platform-software"))}}
        <li><a href="{{siteRootPath}}/platform-software-overview/index.html">Platform Software Overview</a></li>
      {{else if (or (eq page.component.name "platforms-overview") (eq page.component.name "platforms") (isInGroup page.component "platforms") (eq page.component.name "server-platform"))}}
        <li><a href="{{siteRootPath}}/platforms-overview/index.html">Platforms Overview</a></li>
      {{else if (or (eq page.component.name "app-enablement-overview") (isInGroup page.component "application-software") (eq page.component.name "app-enablement"))}}
        <li><a href="{{siteRootPath}}/app-enablement-overview/index.html">Application Enablement Overview</a></li>
      {{/if}}
      {{#if (eq page.component.name "isa")}}
        <li>
          {{!-- Use unversioned link for latest ISA, versioned for others --}}
          {{#if (and page.version (ne page.version "v20260120"))}}
            <a href="{{siteRootPath}}/isa/{{page.version}}/index.html">ISA</a>
          {{else}}
            <a href="{{siteRootPath}}/isa/index.html">ISA</a>
          {{/if}}
        </li>
      {{/if}}
      {{#unless (or (eq page.url "/profiles-overview/index.html") (eq page.url "/hardware-overview/index.html") (eq page.url "/trace-debug-ras-overview/index.html") (eq page.url "/platform-software-overview/index.html") (eq page.url "/app-enablement-overview/index.html") (eq page.url "/platforms-overview/index.html"))}}
      {{#with page.componentVersion}}
        {{#if ./title}}
          {{#if (eq ../page.component.name "isa")}}
            {{#if (eq ../page.module 'priv')}}
              <li><a href="priv-index.html">Privileged</a></li>
            {{else if (eq ../page.module 'unpriv')}}
              <li><a href="unpriv-index.html">Unprivileged</a></li>
            {{else}}
              <li><a href="index.html">ISA Specification</a></li>
            {{/if}}
          {{else}}
            {{#if (eq ../page.module 'priv')}}
              <li><a href="priv-index.html">{{{./title}}}</a></li>
            {{else if (eq ../page.module 'unpriv')}}
              <li><a href="unpriv-index.html">{{{./title}}}</a></li>
            {{else}}
              <li><a href="index.html">{{{./title}}}</a></li>
            {{/if}}
          {{/if}}
        {{/if}}
      {{/with}}
      {{/unless}}
      {{#each page.breadcrumbs}}
        {{#if (and (ne ./content @root.page.componentVersion.title) ./url (eq ./urlType 'internal') (ne ./url @root.page.url))}}
          <li>
            <a href="{{{relativize ./url}}}">{{{./content}}}</a>
          </li>
        {{/if}}
      {{/each}}
    </ul>
    {{/if}}
  </nav>
</div>
{{/unless}}