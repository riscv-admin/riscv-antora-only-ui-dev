<div class="context">
  <span class="title">
    {{#if (eq page.component.name "isa")}}
      <a class="nav-link" href="{{siteRootPath}}/isa/index.html">ISA</a>
    {{else if (or (eq page.component.name "profile") (eq page.component.name "profiles") (eq page.component.name "rva20-rvi20-rva22") (eq page.component.name "rva23") (eq page.component.name "rvb23"))}}
      <a class="nav-link" href="{{siteRootPath}}/profiles-overview/index.html">Profiles</a>
    {{else if (or (eq page.component.name "hardware") (eq page.component.name "aia") (eq page.component.name "iommu") (eq page.component.name "plic") (eq page.component.name "server-soc"))}}
      <a class="nav-link" href="{{siteRootPath}}/hardware-overview/index.html">Hardware</a>
    {{else if (isInGroup page.component "debug-trace-ras")}}
      <a class="nav-link" href="{{siteRootPath}}/trace-debug-ras-overview/index.html">Debug, Trace, RAS</a>
    {{else if (or (eq page.component.name "platform-software") (eq page.component.name "acpi-ffh") (eq page.component.name "semihosting") (eq page.component.name "brs") (eq page.component.name "acpi-rimt") (eq page.component.name "sbi") (eq page.component.name "rpmi") (eq page.component.name "uefi"))}}
      <a class="nav-link" href="{{siteRootPath}}/platform-software-overview/index.html">Platform Software</a>
    {{else if (or (eq page.component.name "app-enablement") (eq page.component.name "vector-c-intrinsics") (eq page.component.name "abi"))}}
      <a class="nav-link" href="{{siteRootPath}}/app-enablement-overview/index.html">Application Enablement</a>
    {{else}}
      {{page.component.title}}
    {{/if}}
  </span>
</div>